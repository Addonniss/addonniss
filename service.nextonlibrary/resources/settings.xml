<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="service.nextonlibrary">
        <category id="skipintro" label="30012">
            <group id="skip_intro">
                <setting id="enable_skip_intro" type="boolean" label="30013" help="30014">
                    <level>0</level>
                    <control type="toggle" />
                    <default>true</default>
                </setting>

                <setting id="online_intro_metadata_priority" type="boolean" label="30025" help="30026">
                    <level>0</level>
                    <control type="toggle" />
                    <default>true</default>
                    <dependencies>
                        <dependency type="enable" setting="enable_skip_intro">true</dependency>
                    </dependencies>
                </setting>

                <setting id="enable_skip_intro_fallback" type="boolean" label="30023" help="30024">
                    <level>0</level>
                    <control type="toggle" />
                    <default>false</default>
                    <dependencies>
                        <dependency type="enable" setting="enable_skip_intro">true</dependency>
                    </dependencies>
                </setting>

                <setting id="skip_intro_fallback_start" type="string" label="30019" help="30020">
                    <level>0</level>
                    <control type="edit" format="string" />
                    <default>00:15</default>
                    <dependencies>
                        <dependency type="enable" setting="enable_skip_intro">true</dependency>
                        <dependency type="enable" setting="enable_skip_intro_fallback">true</dependency>
                    </dependencies>
                </setting>

                <setting id="skip_intro_fallback_end" type="string" label="30021" help="30022">
                    <level>0</level>
                    <control type="edit" format="string" />
                    <default>01:30</default>
                    <dependencies>
                        <dependency type="enable" setting="enable_skip_intro">true</dependency>
                        <dependency type="enable" setting="enable_skip_intro_fallback">true</dependency>
                    </dependencies>
                </setting>
            </group>
        </category>

        <category id="nexton" label="30000">
            <group id="service">
                <setting id="service_enabled" type="boolean" label="30001" help="30002">
                    <level>0</level>
                    <control type="toggle" />
                    <default>true</default>
                </setting>

                <setting id="online_next_metadata_priority" type="boolean" label="30027" help="30028">
                    <level>0</level>
                    <control type="toggle" />
                    <default>true</default>
                </setting>

                <setting id="fallback_trigger_percent" type="integer" label="30005" help="30006">
                    <level>0</level>
                    <constraints>
                        <minimum>50</minimum>
                        <maximum>99</maximum>
                    </constraints>
                    <control type="edit" format="integer" />
                    <default>90</default>
                </setting>
            </group>
        </category>

        <category id="advanced" label="30029">
            <group id="advanced_group" label="30029">
                <setting id="debug_logging" type="boolean" label="30007" help="30008">
                    <level>0</level>
                    <control type="toggle" />
                    <default>false</default>
                </setting>

                <setting id="show_changelog" type="action" label="30030" help="30031">
                    <level>0</level>
                    <control type="button" format="action" />
                    <data>RunScript(service.nextonlibrary,show_changelog)</data>
                </setting>
            </group>
        </category>
    </section>
</settings>
