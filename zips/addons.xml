<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="script.kodiarr.instant"
       name="KodiARR Instant"
       version="1.0.7"
       provider-name="Addonniss">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.28.0"/>
    </requires>

    <extension point="xbmc.python.script" library="launcher.py">
        <provides>executable</provides>
    </extension>

    <extension point="kodi.context.item">
		<menu id="kodi.core.main">

			<item library="default.py" args="radarr">
				<label>Add to Radarr</label>
				<visible>
					String.IsEqual(ListItem.DBType,movie) |
					String.IsEqual(ListItem.Property(item.type),movie)
				</visible>
			</item>

			<item library="default.py" args="sonarr">
				<label>Add to Sonarr</label>
				<visible>
					String.IsEqual(ListItem.DBType,tvshow) |
					String.IsEqual(ListItem.DBType,season) |
					String.IsEqual(ListItem.DBType,episode) |
					String.IsEqual(ListItem.Property(item.type),tvshow) |
					String.IsEqual(ListItem.Property(item.type),season) |
					String.IsEqual(ListItem.Property(item.type),episode)
				</visible>
			</item>

		</menu>
	</extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Send Kodi media items to Radarr or Sonarr instantly</summary>
        <description lang="en_GB">
            Kodi context menu addon that sends movies to Radarr and TV shows,
            seasons, or episodes to Sonarr for automatic download.
        </description>
        <platform>all</platform>
        <license>MIT</license>
		<assets>
            <icon>icon.png</icon>
        </assets>
    </extension>

</addon>
<addon id="service.nextonlibrary" name="Next On Library" version="0.0.2" provider-name="Addonniss">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.python.script" library="launcher.py">
        <provides>executable</provides>
    </extension>
    <extension point="kodi.addon.metadata">
        <summary lang="en_GB">Prompt to play the next library episode using chapter-aware timing.</summary>
        <description lang="en_GB">Monitors library episode playback and offers the next library episode near the end of the current one. It prefers the final chapter marker as the trigger point and falls back to a user-defined playback percentage when no chapters are available. Uses a simple on-screen overlay button.</description>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="service.translatarr" name="Translatarr" version="2.4.12" provider-name="Addonniss">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
    </requires>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.python.script" library="launcher.py">
        <provides>executable</provides>
    </extension>
    <extension point="kodi.addon.metadata">
        <summary lang="en_GB">Subtitle Translator using Gemini, OpenAI, DeepL Free, or LibreTranslate</summary>
        <description lang="en_GB">Automatically detects and translates movie subtitles into your preferred language using Gemini, OpenAI, DeepL Free machine translation, or LibreTranslate. LibreTranslate adds a free self-hosted offline or home-network translation option, giving users more privacy, LAN-speed access, and independence from paid cloud APIs.</description>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="repository.addonniss"
       name="Addonniss Repository"
       version="1.0.1"
       provider-name="Addonniss">

    <extension point="xbmc.addon.repository"
               name="Addonniss Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/Addonniss/repository.addonniss/main/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/Addonniss/repository.addonniss/main/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/Addonniss/repository.addonniss/main/zips/</datadir>
        </dir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Official Repository for Addonniss AI Tools</summary>
        <description>Get the latest updates for Translatarr and other AI-powered Kodi services.</description>
        <platform>all</platform>
    </extension>

</addon>
</addons>
