                <setting id="translation_style" type="string" label="30030" help="30031">
                    <constraints>
                        <options>
                            <option label="Family-Friendly">Family-Friendly</option>
                            <option label="Natural">Natural</option>
                            <option label="Gritty / Adult">Gritty / Adult</option>
                        </options>
                    </constraints>
                    <control type="list" format="string" />
                    <default>Natural</default>
                </setting>

                <setting id="temp" type="string" label="30032" help="30033">
                    <constraints><allowempty>false</allowempty></constraints>
                    <control type="edit" format="string" />
                    <default>0.15</default>
                </setting>

                <setting id="chunk_size" type="integer" label="30019" help="30020">
                    <constraints><minimum>10</minimum><step>10</step><maximum>150</maximum></constraints>
                    <control type="edit" format="integer" />
                    <default>50</default>
                </setting>
            </group>
        </category>

        <category id="advanced" label="30021">
            <group id="4" label="30021">
                <setting id="show_stats" type="boolean" label="30022" help="30023">
                    <control type="toggle" />
                    <default>true</default>
                </setting>
                <setting id="notify_mode" type="boolean" label="30024" help="30025">
                    <control type="toggle" />
                    <default>true</default>
                </setting>
                <setting id="debug_mode" type="boolean" label="30026" help="30027">
                    <control type="toggle" />
                    <default>false</default>
                </setting>
                <setting id="show_changelog" type="action" label="30028" help="30029">
                    <control type="button" format="action" />
                    <data>RunScript(service.translatarr,show_changelog)</data>
                </setting>
            </group>

        </category>
    </section>
</settings>
