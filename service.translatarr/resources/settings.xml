<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="service.translatarr">

        <category id="subtitles" label="30000">
            <group id="1" label="30000">
                <setting id="translation_mode" type="string" label="30039" help="30040">
                    <constraints>
                        <options>
                            <option label="30041">Auto</option>
                            <option label="30042">Manual</option>
                        </options>
                    </constraints>
                    <control type="list" format="string" />
                    <default>Auto</default>
                </setting>

                <setting id="auto_info" type="action" label="30043">
                    <control type="button" format="action" />
                    <dependencies>
                        <dependency type="visible" setting="translation_mode">Auto</dependency>
                    </dependencies>
                </setting>

                <setting id="manual_info" type="action" label="30044">
                    <control type="button" format="action" />
                    <dependencies>
                        <dependency type="visible" setting="translation_mode">Manual</dependency>
                    </dependencies>
                </setting>

                <setting id="sub_folder" type="path" label="30003" help="30004">
                    <constraints><writable>true</writable></constraints>
                    <control type="button" format="path" />
                    <default>/storage/emulated/0/Download/</default>
                    <dependencies>
                        <dependency type="visible" setting="translation_mode">Manual</dependency>
                    </dependencies>
                </setting>

            </group>
        </category>

        <category id="ai_engine" label="30007">
            <group id="2" label="30007">
                <setting id="provider" type="string" label="30008" help="30009">
                    <constraints>
                        <options>
                            <option label="Gemini">Gemini</option>
                            <option label="OpenAI">OpenAI</option>
                        </options>
                    </constraints>
                    <control type="list" format="string" />
                    <default>Gemini</default>
                </setting>

                <setting id="api_key" type="string" label="30010" help="30011">
                    <constraints><allowempty>true</allowempty></constraints>
                    <control type="edit" format="string" />
                    <default />
                    <dependencies>
                        <dependency type="visible" setting="provider">Gemini</dependency>
                    </dependencies>
                </setting>

                <setting id="model" type="string" label="30012" help="30013">
                    <constraints>
                        <options>
                            <option label="Gemini 2.5 Flash">Gemini 2.5 Flash</option>
                            <option label="Fast Mode - Gemini 2.5 Flash">Fast Mode - Gemini 2.5 Flash</option>
                            <option label="Gemini 2.0 Flash (Legacy)">Gemini 2.0 Flash (Legacy)</option>
                            <option label="Gemini 1.5 Flash (Legacy)">Gemini 1.5 Flash (Legacy)</option>
                        </options>
                    </constraints>
                    <control type="list" format="string" />
                    <default>Gemini 2.5 Flash</default>
                    <dependencies>
                        <dependency type="visible" setting="provider">Gemini</dependency>
                    </dependencies>
                </setting>

                <setting id="openai_api_key" type="string" label="30034" help="30035">
                    <constraints><allowempty>true</allowempty></constraints>
                    <control type="edit" format="string" />
                    <default />
                    <dependencies>
                        <dependency type="visible" setting="provider">OpenAI</dependency>
                    </dependencies>
                </setting>

                <setting id="openai_model" type="string" label="30036" help="30037">
                    <constraints>
                        <options>
                            <option label="gpt-4o-mini">gpt-4o-mini</option>
                            <option label="gpt-4o">gpt-4o</option>
                            <option label="gpt-5-mini">gpt-5-mini</option>
                        </options>
                    </constraints>
                    <control type="list" format="string" />
                    <default>gpt-4o-mini</default>
                    <dependencies>
                        <dependency type="visible" setting="provider">OpenAI</dependency>
                    </dependencies>
                </setting>
            </group>
        </category>

		<category id="tuning" label="30014">
