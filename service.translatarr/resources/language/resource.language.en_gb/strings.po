msgstr ""

msgctxt "#30058"
msgid "Select a target language that exists on your LibreTranslate server. Match this with the languages loaded on the server, for example LT_LOAD_ONLY=en,ro."
msgstr ""

msgctxt "#30059"
msgid "SDH/HI cue removal"
msgstr ""

msgctxt "#30060"
msgid "Removes common hearing-impaired subtitle cues such as sound effects, music markers, and speaker labels when they are not spoken dialogue. Tries to preserve actual dialogue."
msgstr ""

msgctxt "#30061"
msgid "Dual-Language Display"
msgstr ""

msgctxt "#30062"
msgid "When enabled, each subtitle entry shows the original source text on the first line and the translated text below it. When disabled, Translatarr keeps the current translated-only display."
msgstr ""

msgctxt "#30063"
msgid "Enable Embedded Subtitle Extraction"
msgstr ""

msgctxt "#30064"
msgid "If no usable subtitle is found during playback, Translatarr can inspect a local MKV or MP4 for embedded subtitles. In Auto mode, extracted source subtitles are written to the Translatarr subtitle folder. In Manual mode, they are written to your configured manual subtitle folder."
msgstr ""

msgctxt "#30065"
msgid "MKVToolNix Executables Folder"
msgstr ""

msgctxt "#30066"
msgid "Optional folder containing mkvinfo and mkvextract. Used for embedded subtitle detection and extraction from MKV files. Leave empty to use the system PATH."
msgstr ""

msgctxt "#30067"
msgid "FFmpeg Executables Folder"
msgstr ""

msgctxt "#30068"
msgid "Optional folder containing ffmpeg and ffprobe. Used for embedded subtitle detection and extraction from MP4 files, and for subtitle conversion when needed. Leave empty to use the system PATH."
msgstr ""

msgctxt "#30071"
msgid "Enable Translation Service"
msgstr ""

msgctxt "#30072"
msgid "Turns the Translatarr background service on or off without disabling the add-on in Kodi. When off, subtitle polling and translation stay paused until you enable it again."
msgstr ""

msgctxt "#30073"
msgid "Skip If Embedded Target Exists"
msgstr ""

msgctxt "#30074"
msgid "When enabled, Translatarr checks whether the video already has an embedded subtitle in your selected target language. If it does, Translatarr skips embedded source extraction and translation for that playback. If no embedded target-language subtitle exists, the normal source extraction and translation flow continues."
msgstr ""

msgctxt "#30075"
msgid "Embedded Subtitles"
msgstr ""

msgctxt "#30076"
msgid "Remote Extractor"
msgstr ""

msgctxt "#30077"
msgid "Enable Remote Extractor"
msgstr ""

msgctxt "#30078"
msgid "Allows Translatarr to call an external subtitle-extraction service when local embedded-subtitle tools are unavailable or when Android should use a remote extractor first."
msgstr ""

msgctxt "#30079"
msgid "Remote Extractor URL"
msgstr ""

msgctxt "#30080"
msgid "Base URL for the remote extractor service, for example http://server:8097. Translatarr will call its /extract endpoint when remote extraction is needed."
msgstr ""

msgctxt "#30081"
msgid "Remote Extractor Token"
msgstr ""

msgctxt "#30082"
msgid "Optional bearer token for the remote extractor service. Leave empty if the service does not require authentication."
msgstr ""

msgctxt "#30083"
msgid "Remote Extractor Timeout"
msgstr ""

msgctxt "#30084"
msgid "Maximum number of seconds Translatarr waits for the remote extractor service to respond before giving up and continuing the normal subtitle flow."
msgstr ""
