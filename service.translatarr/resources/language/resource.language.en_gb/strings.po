msgid "LibreTranslate API Key"
msgstr ""

msgctxt "#30054"
msgid "Optional. Leave empty if your self-hosted LibreTranslate server does not require an API key."
msgstr ""

msgctxt "#30055"
msgid "Source Language (LibreTranslate Server)"
msgstr ""

